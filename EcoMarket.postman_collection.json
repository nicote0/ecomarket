              "path": ["api", "ordenes"]
            },
            "description": "Devuelve el historial de órdenes realizadas. Responde 200 OK."
          },
          "response": []
        },
        {
          "name": "Ver Orden por ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/ordenes/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "ordenes", "1"]
            },
            "description": "Devuelve una orden por su id. Responde 200 OK, o 404 si no existe."
